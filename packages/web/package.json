{
  "name": "sf6-chapter-web",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "build:client": "vite build --config vite.config.client.ts",
    "build:copy-manifest": "cp dist/.vite/manifest.json src/server/manifest.json",
    "build:server": "vite build --config vite.config.ts",
    "build": "pnpm run build:client && pnpm run build:copy-manifest && pnpm run build:server",
    "preview": "wrangler pages dev dist",
    "deploy": "pnpm run build && wrangler pages deploy dist --commit-message=\"Deploy from local\"",
    "typecheck": "tsc --noEmit",
    "test": "TZ=UTC vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/s3-request-presigner": "^3.1054.0",
    "@duckdb/duckdb-wasm": "^1.32.0",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "@hono/vite-dev-server": "^0.26.0",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  }
}
